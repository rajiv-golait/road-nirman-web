# SSR AI Service Configuration

# Must match exactly what the Edge Functions send
AI_SERVICE_SECRET=ssr-demo-secret-2025

# Model Source: "roboflow", "local", or "heuristic"
MODEL_SOURCE=roboflow

# Valid if MODEL_SOURCE=roboflow
# Get this from your Roboflow account settings
ROBOFLOW_API_KEY=your_key_here
ROBOFLOW_MODEL_ID=pothole-detection-gv5e7/3

# Valid if MODEL_SOURCE=local
# Path to your YOLOv8/v12 model weights
LOCAL_MODEL_PATH=models/yolov12s_rdd2022.pt

# Weather (Optional) - Leave blank to use seasonal fallback (0.3 risk factor)
OPENWEATHERMAP_API_KEY=

# Detection Parameters
YOLO_CONFIDENCE=0.65
YOLO_IOU=0.50

# Verification 
SSIM_PASS_THRESHOLD=0.75
