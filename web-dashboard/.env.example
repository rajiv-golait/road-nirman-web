# SSR Web Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values

# Client-side (used by dashboard app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# Public site URL for invite email redirects (optional; defaults to request origin)
# NEXT_PUBLIC_SITE_URL=https://your-dashboard.example.com

# Server-only: required for super_admin "Create user" (Auth Admin invite API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
